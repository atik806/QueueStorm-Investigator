# Server
PORT=3000

# LLM Provider Configuration (optional — fully rule-based without these)
# Set LLM_PROVIDER to "openai" or "anthropic" to enable AI phrasing layer
LLM_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Model override (defaults: gpt-4o-mini for openai, claude-3-haiku-20240307 for anthropic)
LLM_MODEL=
# Timeout per LLM call in milliseconds (default 8000)
LLM_TIMEOUT_MS=8000

# Safety & routing thresholds
# Amount in BDT above which severity is escalated and human review forced
HIGH_VALUE_THRESHOLD_BDT=50000
# Request timeout in milliseconds (hard limit for POST /analyze-ticket)
REQUEST_TIMEOUT_MS=30000
