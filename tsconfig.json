{
  "compilerOptions": {
    /*
     * Hackathon-pragmatic strictness settings:
     *
     * strictNullChecks: ON — required for correct handling of optional fields
     *   (language?, channel?, transaction_history?, metadata?) and
     *   relevant_transaction_id: string | null in responses. Highest-value
     *   null-safety rule for this domain.
     *
     * noImplicitReturns: ON — catches a forgotten enum-return branch in
     *   CaseClassifierService/RouterService at compile time. A missing return
     *   producing `undefined` is an instant schema violation under judging
     *   (Section 14.2, API Contract and Schema, 15% weight). This flag is the
     *   cheapest, highest-leverage addition for THIS specific codebase.
     *
     * noImplicitAny: OFF — class-validator DTOs and rule-based evidence-extraction
     *   heuristics (regex parsing, scoring objects) are written fast, often passing
     *   loosely typed intermediates. Forcing explicit typing adds friction with no
     *   correctness benefit during a timed round.
     *
     * strictPropertyInitialization: OFF — class-validator DTOs declare fields
     *   without initializers, validated at runtime via decorators, not at
     *   construction. Full strict mode would force default values / `!` on every
     *   DTO field for zero actual safety gain.
     *
     * Other strict sub-flags left OFF because they add review surface area without
     *   addressing anything specific to this project's actual risk areas.
     */
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "strictFunctionTypes": false,
    "strictBindCallApply": false,
    "noImplicitThis": false,
    "alwaysStrict": true,

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": false
  }
}
